# Normalize line endings for code and text-based files
*.py  text eol=lf
*.txt text eol=lf
*.md  text eol=lf
*.csv text eol=lf
# Binary files (no diffing or line-ending conversion)
*.mp3 binary
*.mp4 binary
*.npy binary
# Optional: track large model and data files with Git LFS
*.h5  filter=lfs diff=lfs merge=lfs -text
*.pkl filter=lfs diff=lfs merge=lfs -text
*.npy filter=lfs diff=lfs merge=lfs -text
*.mp4 filter=lfs diff=lfs merge=lfs -text
# Optional: image handling
*.jpg binary
*.png binary
*.gif binary
*.bin filter=lfs diff=lfs merge=lfs -text
